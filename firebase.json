{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/player-likee/**",
        "destination": "/pages/player-likee/index.html"
      },
      {
        "source": "/jobs-moscow-ru/**",
        "destination": "/pages/jobs-moscow-ru/jobs-moscow-ru.html"
      },
      {
        "source": "/eva-maria/**",
        "destination": "/pages/eva-maria/index.html"
      },
      {
        "source": "/vse-rabotniki/**",
        "destination": "/pages/vse-rabotniki/index.html"
      },
      {
        "source": "/user/**",
        "destination": "/pages/user/index.html"
      },
      {
        "source": "**/*.@(js|css|png|jpg|jpeg|gif|svg|ico|mp3|webmanifest|json)",
        "destination": "/$1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
