{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/player-likee/**",
        "destination": "/player-likee.html"
      },
      {
        "source": "/user/**",
        "destination": "/user-profile.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
