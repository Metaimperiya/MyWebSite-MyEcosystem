{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/css/**",
        "destination": "/css/$1"
      },
      {
        "source": "/js/**",
        "destination": "/js/$1"
      },
      {
        "source": "**/*.@(js|css|png|jpg|jpeg|gif|svg|ico|mp3|webmanifest|json)",
        "destination": "/$1"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
